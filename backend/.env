# App Settings
APP_NAME=AI Tutor
APP_VERSION=3.0.0
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL=sqlite+aiosqlite:///./ai_tutor.db

# ===========================================
# Redis Configuration
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# LLM Configuration - SiliconFlow DeepSeek-V3
# ===========================================
# Primary LLM for Instructor, Advisor, and all reasoning tasks
OPENAI_API_KEY=sk-idlrukxcujpkyfiqfwrxllzcbrxxvtxigrlzfnkrtwmiypqj
OPENAI_API_BASE=https://api.siliconflow.cn/v1
LLM_MODEL=deepseek-ai/DeepSeek-V3
TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ===========================================
# Vision Model Configuration - SiliconFlow Qwen3-VL
# ===========================================
VISION_MODEL=Qwen/Qwen3-VL-32B-Instruct

# ===========================================
# Embedding Configuration - SiliconFlow Qwen3-Embedding
# ===========================================
