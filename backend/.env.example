# ===========================================
# AI Tutor Environment Configuration
# ===========================================
# This file is pre-configured for competition use
# API Keys are provided for immediate testing

# App Settings
APP_NAME=AI Tutor
APP_VERSION=3.0.0
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# ===========================================
# Database Configuration
# ===========================================
# SQLite (Development - Recommended for quick start)
DATABASE_URL=sqlite+aiosqlite:///./ai_tutor.db

# ===========================================
# Redis Configuration
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# LLM Configuration - SiliconFlow (Pre-configured)
# ===========================================
# Primary LLM: DeepSeek-V3 for math problem solving
OPENAI_API_KEY=sk-ylhosgauteaxdymsjomzrdapgvpgdvvghjdmvpnlbnybekel
OPENAI_API_BASE=https://api.siliconflow.cn/v1
LLM_MODEL=deepseek-ai/DeepSeek-V3
TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Vision Model: Qwen2.5-VL-32B-Instruct for image parsing
VISION_MODEL=Qwen/Qwen2.5-VL-32B-Instruct

# ===========================================
# Embedding Configuration - SiliconFlow (Pre-configured)
# ===========================================
# Embedding Model: Qwen3-Embedding-8B for vector retrieval
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

# SiliconFlow Embedding (using same base URL and key)
SILICONFLOW_API_KEY=sk-szbvplropwsbnneadzuvzoyhzojdhycsnpzncjcwzvjyssva
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1

# ===========================================
# Alternative Providers (Not used, kept for reference)
# ===========================================
# OpenAI (International)
# OPENAI_API_KEY=
# OPENAI_API_BASE=https://api.openai.com/v1
# LLM_MODEL=gpt-3.5-turbo

# DashScope (Alibaba)
# DASHSCOPE_API_KEY=
# DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/api/v1
